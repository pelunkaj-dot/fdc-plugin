  // ─── DISTRACTOR GENERATION ────────────────────────────────────────────────
  const generateDistractors = (level, correctWords, count) => {
    const levelData = DB[level] || {};
    const wordPool = new Set();
    for (const topic of Object.values(levelData)) {
      for (const item of (topic.items || [])) {
        for (const w of wordsFromEN(item.en)) wordPool.add(w);
      }
    }
    const correctSet = new Set(correctWords.map(w => w.toLowerCase()));
    const candidates = [...wordPool].filter(w => !correctSet.has(w.toLowerCase()));
    return shuffle(candidates).slice(0, count);
  };

  // ─── LOCAL EXERCISE PICKER ─────────────────────────────────────────────────
  const getLocalExercise = (level, topicKey, distractorCount) => {
    const topicData = DB[level]?.[topicKey];
    if (!topicData || !topicData.items || topicData.items.length === 0) return null;
    const items = topicData.items;
    const sessionKey = `${level}::${topicKey}`;
    const usedSet = new Set(apiState.usedLocalIdx
      .filter(e => e.key === sessionKey)
      .map(e => e.idx));
    let available = items.map((item, idx) => ({ item, idx })).filter(({ idx }) => !usedSet.has(idx));
    if (available.length === 0) {
      apiState.usedLocalIdx = apiState.usedLocalIdx.filter(e => e.key !== sessionKey);
      available = items.map((item, idx) => ({ item, idx }));
    }
    const { item, idx } = available[Math.floor(Math.random() * available.length)];
    apiState.usedLocalIdx.push({ key: sessionKey, idx });
    const correctWords = wordsFromEN(item.en);
    const distractors  = generateDistractors(level, correctWords, distractorCount);
    return {
      level, topicKey, topicName: topicData.name,
      targetEN: item.en, translationCZ: item.cz,
      words: correctWords, distractors, sourceType: "local"
    };
  };

  // Míchání témat — rotuje přes všechna témata úrovně, z každého vybere jednu větu
  const mixState = { topicKeys: [], currentIdx: 0 };

  const initMixState = (level) => {
    mixState.topicKeys = Object.keys(DB[level] || {});
    mixState.currentIdx = 0;
  };

  const getLocalExerciseMixed = (level, distractorCount) => {
    if (mixState.topicKeys.length === 0) initMixState(level);
    // Zkus najít větu z aktuálního i dalších témat (přeskoč prázdná)
    const total = mixState.topicKeys.length;
    for (let i = 0; i < total; i++) {
      const idx = (mixState.currentIdx + i) % total;
      const topicKey = mixState.topicKeys[idx];
      const ex = getLocalExercise(level, topicKey, distractorCount);
      if (ex) {
        mixState.currentIdx = (idx + 1) % total;
        return ex;
      }
    }
    return null;
  };

