  // ─── HELPERS ─────────────────────────────────────────────────────────────
  const shuffle = (arr) => {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  };
  const clearZone = (z) => { while (z.firstChild) z.removeChild(z.firstChild); };
  const normalizeSentence = (s) => (s || "")
    .toLowerCase()
    .replace(/\s+/g, " ")
    .replace(/\s+([.,!?;:])/g, "$1")
    .trim();
  const sentenceStringFromWords = (words) => {
    let out = "";
    for (const w of words) {
      if (!out) out = w;
      else if (/^[\.\,\?\!\;\:]$/.test(w)) out += w;
      else out += " " + w;
    }
    return out;
  };
  const wordsFromEN = (sentence) => {
    const raw = (sentence || "").trim()
      .replace(/([.,!?;:])/g, " $1 ")
      .replace(/\s+/g, " ")
      .trim()
      .split(" ");
    return raw.filter(Boolean);
  };
  const tokenizeForMeaningCompare = (words) => {
    const ignore = new Set(["a","an","the","to","in","on","at","of","for","with","is","are","am","was","were","do","does","did","have","has","had","will","would","can","could","should","must","that"]);
    return words.map(w => w.toLowerCase())
      .filter(w => !/^[.,!?;:]$/.test(w))
      .filter(w => !ignore.has(w));
  };
  const getWordsInZone = (zone) => [...zone.querySelectorAll(".token")].map(t => t.dataset.value);

