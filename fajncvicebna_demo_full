  const updateRemainingChip = () => {
    if (!current) {
      chipLeft.textContent = "Zbývá vložit: —";
      chipCorrectCount.textContent = "Správná slova: —";
      return;
    }
    const expected = current.words.map(w => w.toLowerCase());
    const built    = getWordsInZone(builderEl).map(w => w.toLowerCase());
    const bag = new Map();
    for (const w of expected) bag.set(w, (bag.get(w) || 0) + 1);
    let matchedNow = 0;
    for (const w of built) {
      const n = bag.get(w) || 0;
      if (n > 0) { matchedNow++; bag.set(w, n - 1); }
    }
    let remaining = 0;
    for (const n of bag.values()) remaining += n;
    chipLeft.textContent = `Zbývá vložit: ${remaining}`;
    chipCorrectCount.textContent = `Správná slova: ${matchedNow}/${expected.length}`;
  };

  const updateBuiltSentence = () => {
    const words = getWordsInZone(builderEl);
    const s = sentenceStringFromWords(words).trim();
    builtSentenceEl.innerHTML = "";
    if (!s) {
      const ph = document.createElement("span");
      ph.className = "placeholder";
      ph.textContent = "— (zatím prázdné)";
      builtSentenceEl.appendChild(ph);
    } else {
      builtSentenceEl.textContent = s;
    }
    updateRemainingChip();
  };

  // ─── PROGRESS ─────────────────────────────────────────────────────────────
  const loadProg = () => {
    try {
      const raw = localStorage.getItem(PROG_KEY);
      if (raw) {
        const obj = JSON.parse(raw);
        if (obj && typeof obj === "object") {
          prog = {
            xp:       Number(obj.xp       || 0),
            streak:   Number(obj.streak   || 0),
            demoDone: Number(obj.demoDone || 0),
            level:    Number(obj.level    || 1)
          };
        }
      }
    } catch (_) {}
    recomputeLevelFromXP();
    renderProg();
  };

  const saveProg = () => {
    try { localStorage.setItem(PROG_KEY, JSON.stringify(prog)); } catch (_) {}
  };

  const recomputeLevelFromXP = () => {
    prog.level = Math.max(1, Math.floor(Math.max(0, prog.xp) / XP_PER_LEVEL) + 1);
  };

  const renderProg = () => {
    xpVal.textContent       = String(prog.xp);
    streakVal.textContent   = String(prog.streak);
    demoDoneVal.textContent = FULL_MODE ? "∞" : String(Math.min(prog.demoDone, DEMO_GOAL));
    lvlVal.textContent      = String(prog.level);
    const inLevel = prog.xp % XP_PER_LEVEL;
    lvlProgText.textContent = `${inLevel}/${XP_PER_LEVEL}`;

    const demoChip = demoDoneVal?.closest(".chip");
    if (demoChip) {
      if (FULL_MODE) {
        demoChip.innerHTML = `💎 Režim: <b>Plná verze</b>`;
      } else {
        demoChip.innerHTML = `🧪 Demo: <b id="demoDoneVal">${Math.min(prog.demoDone, DEMO_GOAL)}</b>/${DEMO_GOAL}`;
      }
    }
  };

  const ensureDemoAccess = () => {
    if (FULL_MODE) return true;
    if (prog.demoDone >= DEMO_GOAL) {
      showModal();
      setStatus("warn", "🟨 Demo bylo vyčerpáno.", "Pokračuj přes rozcestník do plné verze.");
      return false;
    }
    return true;
  };

  const addXP = (amount) => {
    prog.xp = Math.max(0, prog.xp + Math.max(0, Math.floor(amount)));
    recomputeLevelFromXP();
    saveProg();
    renderProg();
    pulseChip(document.querySelector(".chip"));
  };

  const setStreak = (n) => {
    prog.streak = Math.max(0, Math.floor(n));
    saveProg();
    renderProg();
    pulseChip(streakVal.closest(".chip"));
  };

  const incDemoDone = () => {
    if (FULL_MODE) return;
    prog.demoDone = Math.max(0, prog.demoDone + 1);
    saveProg();
    renderProg();
    if (prog.demoDone >= DEMO_GOAL) showModal();
  };

  const resetProg = () => {
    if (!confirm("Opravdu chceš vynulovat XP a postup v tomto prohlížeči?")) return;
    prog = { xp: 0, streak: 0, demoDone: 0, level: 1 };
    saveProg();
    renderProg();
    setStatus("", "Resetováno. Vyber úroveň a téma nebo napiš vlastní větu.", "—");
  };

  const showModal = () => modalBack.classList.add("show");
  const hideModal = () => modalBack.classList.remove("show");

  // ─── TOPIC DROPDOWN ────────────────────────────────────────────────────────
  const refreshTopics = () => {
    const level  = levelSel.value;
    const topics = DB[level] || {};
    const keys   = Object.keys(topics);
    const prev   = topicSel.value;
    topicSel.innerHTML = "";
    for (const k of keys) {
      const opt = document.createElement("option");
      opt.value = k;
      opt.textContent = topics[k].name;
      topicSel.appendChild(opt);
    }
    if (prev && keys.includes(prev)) topicSel.value = prev;
    else if (keys.length > 0)        topicSel.value = keys[0];
  };

  // ─── MODE ──────────────────────────────────────────────────────────────────
  const setMode = (m) => {
    mode = m;
    const isComm = mode === "comm";
    modeCommBtn.classList.toggle("active",  isComm);
    modeSchoolBtn.classList.toggle("active", !isComm);
    modeCommBtn.setAttribute("aria-selected",  String(isComm));
    modeSchoolBtn.setAttribute("aria-selected", String(!isComm));
    pillMode.textContent  = isComm ? "Domluvit se" : "Do školy";
    chipMode.textContent  = "Režim: " + (isComm ? "Domluvit se" : "Do školy");
    document.body.className = isComm ? "mode-comm" : "mode-school";
    modeStrip.className = "modeStrip " + (isComm ? "comm" : "school");
    modeStrip.innerHTML = isComm
      ? "🗣️ Režim: <strong>Domluvit se</strong> — toleruje drobné chyby, pokud je věta srozumitelná."
      : "🎓 Režim: <strong>Do školy</strong> — přísné hodnocení, gramatika musí být správná.";
    if (current) {
      setStatus("", "📌 Složte větu a klikněte Vyhodnotit.",
        isComm ? "Cíl: domluvit se — toleruje drobné chyby."
               : "Cíl: do školy — přísnější hodnocení.");
    }
  };

  // ─── SPEECH ───────────────────────────────────────────────────────────────
  const pickPreferredVoice = () => {
    const synth = window.speechSynthesis;
    if (!synth) return null;
    const voices = synth.getVoices() || [];
    return voices.find(v => v.lang.toLowerCase().startsWith("en-gb"))
        || voices.find(v => v.lang.toLowerCase().startsWith("en-us"))
        || voices.find(v => v.lang.toLowerCase().startsWith("en"))
        || null;
  };

  const speak = (text, rate = 1.0) => {
    const synth = window.speechSynthesis;
    if (!synth || !window.SpeechSynthesisUtterance) {
      setStatus("warn", "⚠️ Prohlížeč nepodporuje čtení nahlas (Web Speech API).", "Zkus Chrome nebo Edge.");
      return;
    }
    synth.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.rate = rate;
    if (!preferredVoice) preferredVoice = pickPreferredVoice();
    if (preferredVoice) u.voice = preferredVoice;
    synth.speak(u);
  };

  if ("speechSynthesis" in window) {
    window.speechSynthesis.onvoiceschanged = () => { preferredVoice = pickPreferredVoice(); };
  }
  preferredVoice = pickPreferredVoice();
  chipSlow.textContent = `Pomalu: ${String(SLOW_RATE).replace(".", ",")}×`;

  // ─── TOKENS (no arrows) ───────────────────────────────────────────────────
  const makeToken = (text) => {
    const el = document.createElement("div");
    el.className     = "token";
    el.draggable     = true;
    el.dataset.value = text;
    el.tabIndex      = 0;
    el.textContent   = text;

    el.addEventListener("dragstart", (e) => {
      el.classList.add("dragging");
      e.dataTransfer.setData("text/plain", "token");
      e.dataTransfer.effectAllowed = "move";
    });
    el.addEventListener("dragend", () => {
      el.classList.remove("dragging");
      updateBuiltSentence();
    });
    el.addEventListener("click", () => {
      const parent = el.parentElement;
      if (parent === bankEl) builderEl.appendChild(el);
      else bankEl.appendChild(el);
      clearMarks();
      setStatus("", "📌 Složte větu a klikněte Vyhodnotit.", "Tip: slova přesunete kliknutím nebo přetažením.");
      updateBuiltSentence();
    });
    return el;
  };

  // ─── DRAG & DROP ZONES ────────────────────────────────────────────────────
  const getClosestToken = (container, x, y) => {
    const tokens = [...container.querySelectorAll(".token:not(.dragging)")];
    if (tokens.length === 0) return null;
    let best = { dist: Infinity, el: null };
    for (const t of tokens) {
      const r  = t.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top  + r.height / 2;
      const d  = Math.hypot(x - cx, y - cy);
      if (d < best.dist) best = { dist: d, el: t };
    }
    return best.el;
  };

  const enableDropZone = (zone) => {
    zone.addEventListener("dragover", (e) => {
      e.preventDefault();
      zone.classList.add("isOver");
      const dragging = document.querySelector(".token.dragging");
      if (!dragging) return;
      const afterEl = getClosestToken(zone, e.clientX, e.clientY);
      if (afterEl == null) zone.appendChild(dragging);
      else zone.insertBefore(dragging, afterEl);
    });
    zone.addEventListener("dragleave", () => zone.classList.remove("isOver"));
    zone.addEventListener("drop", (e) => {
      e.preventDefault();
      zone.classList.remove("isOver");
      clearMarks();
      setStatus("", "📌 Složte větu a klikněte Vyhodnotit.");
      updateBuiltSentence();
    });
  };
  enableDropZone(bankEl);
  enableDropZone(builderEl);

  // ─── LOAD EXERCISE ────────────────────────────────────────────────────────
  const loadExercise = (ex) => {
    current = ex;
    pillTopic.textContent  = ex.topicName;
    pillLevel.textContent  = ex.level;
    pillMode.textContent   = (mode === "comm") ? "Domluvit se" : "Do školy";
    chipMode.textContent   = "Režim: " + ((mode === "comm") ? "Domluvit se" : "Do školy");
    pillSource.style.display = "inline-flex";
    pillSource.textContent = ex.sourceType === "local" ? "📦 lokální"
                           : ex.sourceType === "custom" ? "✏️ vlastní" : "🤖 AI";
    translationShown = false;
    translationEl.textContent = ex.translationCZ || "(bez překladu)";
    translationEl.classList.remove("show");
    toggleTrBtn.textContent = "Zobrazit překlad";
    clearZone(bankEl);
    clearZone(builderEl);
    clearMarks();
    const bankWords = shuffle([...ex.words, ...ex.distractors]);
    bankWords.forEach(w => bankEl.appendChild(makeToken(w)));
    updateBuiltSentence();
    targetHint.textContent = "Složte větu a klikněte Vyhodnotit.";
    setStatus("", "✅ Cvičení připraveno. Nyní skládejte.",
      `Zdroj: ${ex.sourceType} • Úroveň: ${ex.level} • Rušiče: ${ex.distractors.length}`);
  };

  // ─── API FETCH ────────────────────────────────────────────────────────────
  const fetchWithTimeout = async (url, options, timeoutMs) => {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), timeoutMs);
    try {
      const res = await fetch(url, { ...options, signal: controller.signal });
      clearTimeout(timer);
      return res;
    } catch (err) {
      clearTimeout(timer);
      throw err;
    }
  };

  const normalizeApiExercise = (data, requestMode, level, topicKey, topicName) => {
    const correctWords  = Array.isArray(data.correctWords) && data.correctWords.length
      ? data.correctWords : wordsFromEN(data.targetSentence || "");
    const distractors   = Array.isArray(data.extraWords) ? data.extraWords : [];
    const targetEN      = data.targetSentence || sentenceStringFromWords(correctWords);
    const translationCZ = data.translationCs || "";
    const sourceType    = data.sourceType || (requestMode === "custom" ? "custom" : "api");
    return { level, topicKey, topicName, targetEN, translationCZ, words: correctWords, distractors, sourceType };
  };

  const tryFetchFromApi = async (payload) => {
    const res = await fetchWithTimeout(
      API_URL,
      { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) },
      API_TIMEOUT_MS
    );
    if (!res.ok) { const errText = await res.text().catch(() => ""); throw new Error(`HTTP ${res.status}: ${errText}`); }
    return res.json();
  };

  // ─── MAIN EXERCISE CREATORS ───────────────────────────────────────────────
  const createTopicExercise = async () => {
    if (loadingActive) return;
    if (!ensureDemoAccess()) return;
    apiState.lastMode = "topic";
    const level    = levelSel.value;
    const topicKey = topicSel.value;
    const topicName = DB[level]?.[topicKey]?.name
      || topicSel.options[topicSel.selectedIndex]?.textContent
      || topicKey;
    const distractorCount = Number(distrSel.value || 2);

    // Míchání témat
    if (mixToggle.checked) {
      const mixEx = getLocalExerciseMixed(level, distractorCount);
      if (mixEx) { loadExercise(mixEx); return; }
    }

    const localEx = getLocalExercise(level, topicKey, distractorCount);
    if (localEx) { loadExercise(localEx); return; }

    loadingActive = true;
    setButtonLoading(createTopicBtn, true);
    setStatus("", "⏳ Načítám cvičení z AI…", "Prosím, chvíli strpení.");
    try {
      const payload = { level, topic: topicKey, sourceType: "preset", usedIds: apiState.usedIds };
      const data = await tryFetchFromApi(payload);
      if (data.id && !apiState.usedIds.includes(data.id)) apiState.usedIds.push(data.id);
      const ex = normalizeApiExercise(data, "topic", level, topicKey, topicName);
      loadExercise(ex);
    } catch (err) {
      console.error("API error (topic):", err);
      const isTimeout = err.name === "AbortError";
      setStatus("bad",
        isTimeout ? "🟥 AI server neodpověděl včas." : "🟥 AI backend je nedostupný.",
        "Pro toto téma nejsou lokální data. Zkus jiné téma (⭐ = funguje offline).");
    } finally {
      loadingActive = false;
      setButtonLoading(createTopicBtn, false);
    }
  };

  const translateCzechToEnglish = async (czText) => {
    try {
      const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(czText)}&langpair=cs|en`;
      const res = await fetchWithTimeout(url, {}, 8000);
      if (res.ok) {
        const data = await res.json();
        const translated = data?.responseData?.translatedText;
        if (translated && !translated.startsWith("MYMEMORY WARNING")) return translated.trim();
      }
    } catch (_) {}
    try {
      const payload = { level: levelSel.value, topic: "custom", sourceType: "custom", usedIds: [], sentenceCs: czText };
      const data = await tryFetchFromApi(payload);
      if (data?.targetSentence) return data.targetSentence.trim();
    } catch (_) {}
    throw new Error("translation_failed");
  };

  const createCustomExercise = async () => {
    if (loadingActive) return;
    if (!ensureDemoAccess()) return;
    apiState.lastMode = "custom";
    const czSentence = customSentenceInput.value.trim();
    if (!czSentence) { setStatus("bad", "🟥 Nejdříve napište českou větu.", "Pole ‚Vlastní věta' je prázdné."); return; }
    const level = levelSel.value;
    const distractorCount = Number(distrSel.value || 2);
    loadingActive = true;
    setButtonLoading(createCustomBtn, true);
    setStatus("", "⏳ Překládám větu…", "Používám překlad MyMemory (zdarma).");
    try {
      const enSentence   = await translateCzechToEnglish(czSentence);
      const correctWords = wordsFromEN(enSentence);
      let distractors = generateDistractors(level, correctWords, distractorCount);
      if (distractors.length < distractorCount) {
        const extra = ["because","although","however","before","after","usually","really","just","still","already","also","often","never","always","very","too","quite","both","either","neither"]
          .filter(w => !correctWords.map(x => x.toLowerCase()).includes(w))
          .slice(0, distractorCount - distractors.length);
        distractors = [...distractors, ...extra];
      }
      loadExercise({ level, topicKey: "custom", topicName: "Vlastní věta",
        targetEN: enSentence, translationCZ: czSentence,
        words: correctWords, distractors, sourceType: "custom" });
    } catch (err) {
      console.error("Custom exercise error:", err);
      setStatus("bad", "🟥 Překlad se nezdařil.", "Zkontroluj připojení k internetu. Překlad zajišťuje MyMemory (zdarma).");
    } finally {
      loadingActive = false;
      setButtonLoading(createCustomBtn, false);
    }
  };

  const nextExercise = () => {
    if (!ensureDemoAccess()) return;
    if (apiState.lastMode === "custom") return createCustomExercise();
    return createTopicExercise();
  };

  // ─── EVALUATE ─────────────────────────────────────────────────────────────
  const buildFeedbackForSchool = (builtWords) => {
    const built  = builtWords.map(w => w.toLowerCase());
    const target = current.words.map(w => w.toLowerCase());
    const bag    = new Map();
    for (const w of target) bag.set(w, (bag.get(w) || 0) + 1);
    const missing = [];
    for (const w of built) { const n = bag.get(w) || 0; if (n > 0) bag.set(w, n - 1); }
    for (const [w, n] of bag.entries()) { if (n > 0 && !/^[.,!?;:]$/.test(w)) missing.push(w); }
    const functionWords = ["a","an","the","to","in","on","at","for","with","have","has","had","am","is","are","was","were","will","would","do","does","did"];
    const mf = missing.filter(w => functionWords.includes(w)).slice(0, 3);
    const mc = missing.filter(w => !functionWords.includes(w)).slice(0, 3);
    if (mc.length) return `Chybí klíčové slovo/a: ${mc.join(", ")}.`;
    if (mf.length) return `Pozor na gramatiku: chybí ${mf.join(", ")}.`;
    return "Zkus doladit slovosled a drobnou gramatiku.";
  };

  const buildFeedbackForComm = (builtWords) => {
    const builtMeaning  = tokenizeForMeaningCompare(builtWords);
    const targetMeaning = tokenizeForMeaningCompare(current.words);
    const targetSet     = new Set(targetMeaning);
    const wrong = builtMeaning.filter(w => !targetSet.has(w));
    if (wrong.length) return `Možná máš navíc nebo špatně: ${wrong.slice(0, 3).join(", ")}.`;
    if (builtMeaning.length < Math.max(2, Math.floor(targetMeaning.length * 0.6)))
      return "Chybí část významu — zkus doplnit hlavní slova.";
    return "Skoro perfektní — doladíš slovosled a bude to.";
  };

  const awardForGreen = () => {
    let xp = 10;
    const nextStreak = prog.streak + 1;
    if (nextStreak >= 5) xp += 10;
    else if (nextStreak >= 3) xp += 5;
    if (mode === "school") xp += 2;
    setStreak(nextStreak);
    addXP(xp);
    if (!FULL_MODE && prog.demoDone < DEMO_GOAL) incDemoDone();
    return xp;
  };

  const evaluate = () => {
    if (!current) {
      setStatus("warn", "🟨 Nejdřív vytvoř cvičení.", "Vyber úroveň a téma nebo napiš vlastní větu.");
      return;
    }
    clearMarks();
    const builtWords = getWordsInZone(builderEl);
    const builtStr   = normalizeSentence(sentenceStringFromWords(builtWords));
    const targetStr  = normalizeSentence(current.targetEN);

    if (builtStr === targetStr) {
      [...builderEl.querySelectorAll(".token")].forEach(t => t.classList.add("correct"));
      builderEl.classList.remove("correctFlash");
      void builderEl.offsetWidth;
      builderEl.classList.add("correctFlash");
      const earned = awardForGreen();
      spawnConfetti();
      spawnXpBurst(earned);
      targetHint.textContent = "Výborně! Teď větu přehraj a zopakuj nahlas.";
      const streakMsg = prog.streak >= 5 ? ` 🔥 Série ${prog.streak}!` : prog.streak >= 3 ? " 🔥 Dobrá série!" : "";
      setStatus("good",
        `🟩 Gramaticky správně! (+${earned} XP)${streakMsg}`,
        `🔥 Série: ${prog.streak} • ⭐ XP: ${prog.xp} • 🧪 Demo: ${Math.min(prog.demoDone, DEMO_GOAL)}/${DEMO_GOAL}`);
      if (autoSpeakToggle.checked) speak(builtStr, SLOW_RATE);
      return;
    }

    const expectedMeaning = tokenizeForMeaningCompare(current.words);
    const builtMeaning    = tokenizeForMeaningCompare(builtWords);
    const bag = new Map();
    for (const w of builtMeaning) bag.set(w, (bag.get(w) || 0) + 1);
    let matched = 0;
    for (const w of expectedMeaning) {
      const n = bag.get(w) || 0;
      if (n > 0) { matched++; bag.set(w, n - 1); }
    }
    const coverage         = expectedMeaning.length ? (matched / expectedMeaning.length) : 0;
    const expectedSet      = new Set(expectedMeaning);
    const wrongMeaningCount = builtMeaning.filter(w => !expectedSet.has(w)).length;

    [...builderEl.querySelectorAll(".token")].forEach((t, i) => {
      t.classList.add(current.words[i] === t.dataset.value ? "correct" : "wrong");
    });

    builderEl.classList.remove("wrongShake");
    void builderEl.offsetWidth;
    builderEl.classList.add("wrongShake");
    setStreak(0);

    if (mode === "comm") {
      if (coverage >= 0.65 && wrongMeaningCount <= 2) {
        targetHint.textContent = "Srozumitelné — ale gramatiku ještě dolaď.";
        setStatus("warn",
          "🟨 Domluvil/a by ses, ale gramatika není správná.",
          buildFeedbackForComm(builtWords) + " " + randTip());
      } else {
        targetHint.textContent = "Zkus to znovu. Při potížích klikni na Srovnat (nápověda).";
        setStatus("bad", "🟥 Tato věta není srozumitelná.", buildFeedbackForComm(builtWords) + " " + randTip());
      }
      return;
    }

    if (coverage >= 0.80 && wrongMeaningCount <= 1) {
      targetHint.textContent = "Skoro! Chybí detail — slovosled nebo drobná gramatika.";
      setStatus("warn",
        "🟨 Skoro správně, ale do školy to nestačí.",
        buildFeedbackForSchool(builtWords) + " " + randTip());
    } else {
      targetHint.textContent = "Zkus to znovu. Při potížích klikni na Srovnat (nápověda).";
      setStatus("bad", "🟥 Tato věta je špatně.", buildFeedbackForSchool(builtWords) + " " + randTip());
    }
  };

  // ─── HINT ─────────────────────────────────────────────────────────────────
  const hintAlign = () => {
    if (!current) {
      setStatus("warn", "🟨 Nejdřív vytvoř cvičení.", "Pak teprve má nápověda smysl.");
      return;
    }
    clearMarks();
    const allTokens = [...bankEl.querySelectorAll(".token"), ...builderEl.querySelectorAll(".token")];
    const byWord = new Map();
    for (const t of allTokens) {
      const w = t.dataset.value;
      if (!byWord.has(w)) byWord.set(w, []);
      byWord.get(w).push(t);
    }
    clearZone(builderEl);
    for (const w of current.words) {
      const list = byWord.get(w) || [];
      builderEl.appendChild(list.shift() || makeToken(w));
    }
    clearZone(bankEl);
    const remaining = [];
    for (const list of byWord.values()) for (const t of list) remaining.push(t);
    shuffle(remaining).forEach(t => bankEl.appendChild(t));
    targetHint.textContent = "Nápověda použita. Teď klikni Vyhodnotit.";
    setStatus("warn", "🟨 Srovnáno (nápověda).", "Rušiče zůstaly v bance.");
    clearMarks();
    updateBuiltSentence();
  };

  const clearBuilder = () => {
    [...builderEl.querySelectorAll(".token")].forEach(t => bankEl.appendChild(t));
    clearMarks();
    setStatus("", "📌 Vyčištěno. Zkus to znovu.", "Tip: slova přesunuješ kliknutím nebo přetažením.");
    updateBuiltSentence();
  };

  const shuffleBank = () => {
    const tokens = [...bankEl.querySelectorAll(".token")];
    clearZone(bankEl);
    shuffle(tokens).forEach(t => bankEl.appendChild(t));
    clearMarks();
    setStatus("", "📌 Zamícháno.", "Banka je znovu zamíchaná.");
  };

  const toggleTranslation = () => {
    if (!current) {
      setStatus("warn", "🟨 Nejdřív vytvoř cvičení.", "Pak si můžeš zobrazit překlad.");
      return;
    }
    translationShown = !translationShown;
    translationEl.classList.toggle("show", translationShown);
    toggleTrBtn.textContent = translationShown ? "Skrýt překlad" : "Zobrazit překlad";
  };

  const getBuiltTextOrWarn = () => {
    const s = sentenceStringFromWords(getWordsInZone(builderEl)).trim();
    if (!s) { setStatus("warn", "🟨 Nejdřív slož větu.", "Pak ji přehraj."); return null; }
    return s;
  };

  // ─── EVENT LISTENERS ──────────────────────────────────────────────────────
  levelSel.addEventListener("change", () => {
    apiState.usedIds      = [];
    apiState.usedLocalIdx = [];
    mixState.topicKeys    = [];
    refreshTopics();
    setStatus("", "📌 Vyber téma a klikni Vytvořit cvičení z tématu.", "Změnila se úroveň.");
  });
  topicSel.addEventListener("change", () => {
    apiState.usedIds      = [];
    apiState.usedLocalIdx = [];
    setStatus("", "📌 Klikni Vytvořit cvičení z tématu.", "Změnilo se téma.");
  });
  mixToggle.addEventListener("change", () => {
    topicSel.disabled = mixToggle.checked;
    if (mixToggle.checked) {
      initMixState(levelSel.value);
      setStatus("", "🔀 Míchání témat zapnuto.", "Každá věta bude z jiného tématu v rámci vybrané úrovně.");
    } else {
      setStatus("", "📌 Vyber téma a klikni Vytvořit cvičení z tématu.", "Míchání vypnuto.");
    }
  });
  modeCommBtn.addEventListener("click",   () => setMode("comm"));
  modeSchoolBtn.addEventListener("click",  () => setMode("school"));
  flagToggle.addEventListener("change", () => {
    bgFlag.style.display = flagToggle.checked ? "block" : "none";
  });
  createTopicBtn.addEventListener("click",  createTopicExercise);
  createCustomBtn.addEventListener("click", createCustomExercise);
  nextBtnLeft.addEventListener("click",     nextExercise);
  nextBtn.addEventListener("click",         nextExercise);
  shuffleBtn.addEventListener("click",  shuffleBank);
  clearBtn.addEventListener("click",    clearBuilder);
  toggleTrBtn.addEventListener("click", toggleTranslation);
  evalBtn.addEventListener("click",  evaluate);
  hintBtn.addEventListener("click",  hintAlign);
  speakerBtn.addEventListener("click", () => { const s = getBuiltTextOrWarn(); if (s) speak(s, 1.0); });
  slowBtn.addEventListener("click",    () => { const s = getBuiltTextOrWarn(); if (s) speak(s, SLOW_RATE); });
  distrSel.addEventListener("change", () => {
    if (current) setStatus("", "⚙️ Počet rušičů se použije v dalším cvičení.", "Klikni Nové cvičení.");
  });
  resetProgBtn.addEventListener("click",  resetProg);
  closeModalBtn.addEventListener("click", hideModal);
  modalBack.addEventListener("click",     (e) => { if (e.target === modalBack) hideModal(); });
  document.addEventListener("keydown",    (e) => { if (e.key === "Escape") hideModal(); });

  // ─── INIT ─────────────────────────────────────────────────────────────────
  const init = () => {
    loadProg();
    refreshTopics();
    setMode("comm");
    bgFlag.style.display = flagToggle.checked ? "block" : "none";
    if (FULL_MODE) {
      setStatus("", "💎 Plná verze je aktivní.", "Můžeš cvičit bez demo limitu.");
    } else if (prog.demoDone >= DEMO_GOAL) {
      setStatus("warn", "🟨 Demo bylo vyčerpáno.", "Pokračuj přes rozcestník do plné verze.");
      showModal();
    } else {
      setStatus("", "📌 Vyber úroveň a téma vlevo, nebo napiš vlastní větu.", "Témata s ⭐ fungují i bez internetu.");
    }
    updateBuiltSentence();
  };
  init();
})();
</script>
</body>
</html>
